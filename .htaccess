# ============================================================
# Belu Francia · .htaccess · Hostinger
# Cache + Compresión + Seguridad básica
# ============================================================

# ── MIME TYPES ──────────────────────────────────────────────
AddType image/webp .webp
AddType font/woff2 .woff2
AddType application/javascript .js

# ── GZIP COMPRESIÓN ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE text/plain application/json image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 application/font-woff2
</IfModule>

# ── CACHE HEADERS ───────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML — sin caché (siempre fresco)
  ExpiresByType text/html "access plus 0 seconds"
  
  # CSS y JS — 1 mes (con cache buster ?v= en el HTML)
  ExpiresByType text/css                "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"
  
  # Imágenes — 6 meses
  ExpiresByType image/jpeg              "access plus 6 months"
  ExpiresByType image/png               "access plus 6 months"
  ExpiresByType image/webp              "access plus 6 months"
  ExpiresByType image/gif               "access plus 6 months"
  ExpiresByType image/svg+xml           "access plus 6 months"
  ExpiresByType image/x-icon            "access plus 1 year"
  
  # Fuentes — 1 año
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType application/font-woff   "access plus 1 year"
</IfModule>

# ── SEGURIDAD BÁSICA ─────────────────────────────────────────
# Ocultar versión del servidor
ServerSignature Off

# Prevenir listado de directorios
Options -Indexes

# Proteger .htaccess
<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

# Headers de seguridad básicos
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── URLS LIMPIAS (sin .html) ─────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirigir www → sin www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Forzar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # URLs sin .html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^([^.]+)$ $1.html [L]
</IfModule>

# ── 404 PERSONALIZADO ────────────────────────────────────────
ErrorDocument 404 /pages/404.html
